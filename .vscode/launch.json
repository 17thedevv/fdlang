{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Mellis Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode"
            ],
            "outFiles": [
                "${workspaceFolder}/editors/vscode/out/**/*.js"
            ],
            "preLaunchTask": "npm: compile"
        }
    ]
}
