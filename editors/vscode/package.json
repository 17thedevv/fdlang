{
  "name": "mellis",
  "displayName": "Mellis",
  "description": "Mellis Language Support",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mellis"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mellis",
        "aliases": ["Mellis", "mellis"],
        "extensions": [".ms"]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^16.x",
    "typescript": "^4.9.5"
  }
}
